{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/auto-format.js"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context-mode@claude-context-mode": true
  }
}
